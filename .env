# Local network host IP — used by Vite dev server to bind on the LAN.
# Update this to match your machine's current IP address.
VITE_HOST_IP=192.168.0.46

# Optional: explicitly pin the backend API / WebSocket base URLs.
# If unset the app derives them from window.location.hostname at runtime,
# which works automatically on any machine on the LAN.
# VITE_API_BASE=http://192.168.0.46:8000
# VITE_WS_BASE=ws://192.168.0.46:8000
